# Security + caching headers for Cloudflare Pages static assets.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; img-src 'self' https://images.unsplash.com data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'; connect-src 'self'; frame-src https://checkout.paystack.com; form-action 'self' https://checkout.paystack.com; base-uri 'self'; object-src 'none'

# Cache hashed build assets aggressively (filenames are content-hashed).
/assets/*
  Cache-Control: public, max-age=31536000, immutable
